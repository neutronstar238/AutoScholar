# ===== AutoScholar 环境变量配置 =====
# 复制此文件为 .env 并填入实际值

# ===== 基础配置 =====
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ===== 数据库配置 =====
DATABASE_URL=postgresql://autoscholar:autoscholar@localhost:5432/autoscholar
REDIS_URL=redis://localhost:6379/0

# ===== AI 模型配置 =====

# 方案 1: API 模式 (推荐 - 双提供商自动回退)
# Qwen3.5 (优先使用)
QWEN35_API_KEY=sk-your-qwen35-api-key-here
QWEN35_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN35_MODEL=qwen-plus

# Qwen (备选回退)
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# 模型提供商优先级 (默认 Qwen3.5，失败则回退到 Qwen)
MODEL_PROVIDERS=qwen3.5,qwen
PRIMARY_PROVIDER=qwen3.5
FALLBACK_PROVIDER=qwen

# 其他可选提供商
# DeepSeek
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# 方案 2: Ollama 模式 (企业私有化部署)
# 如需本地部署，设置以下配置
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===== 前端配置 =====
FRONTEND_URL=http://localhost:3000

# ===== 平台集成配置 (可选) =====

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# 企业微信
WECOM_CORP_ID=
WECOM_AGENT_SECRET=

# 钉钉
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# ===== 商业化配置 =====
API_KEY_SECRET=change-this-to-a-random-secret-key-in-production
STRIPE_SECRET_KEY=
